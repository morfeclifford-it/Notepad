<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1D1D1D"
    tools:context=".LoginNotepad">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.128">

        <ImageView
            android:id="@+id/loginLogo"
            android:layout_width="163dp"
            android:layout_height="162dp"
            android:layout_gravity="center"
            android:layout_marginTop="30sp"
            app:srcCompat="@drawable/notepadicon" />

        <TextView
            android:id="@+id/welcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25sp"
            android:fontFamily="sans-serif-light"
            android:text="Welcome To Notepad!"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="25sp" />

        <EditText
            android:id="@+id/LoginEmailAddress"
            android:layout_width="250sp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="40sp"
            android:ems="10"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:textColorHint="#979797" />

        <EditText
            android:id="@+id/LoginPassword3"
            android:layout_width="250sp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="40sp"
            android:layout_marginRight="40sp"
            android:ems="10"
            android:hint="Password"
            android:inputType="textPassword"
            android:textColorHint="#979797"
            app:layout_constraintStart_toStartOf="parent" />

        <Button
            android:id="@+id/Loginbutton"
            android:layout_width="251dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:layout_marginTop="40sp"
            android:layout_marginBottom="15sp"
            android:backgroundTint="#2F2F2F"
            android:fontFamily="sans-serif-light"
            android:text="Login"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10sp"
            android:fontFamily="sans-serif-light"
            android:text="Dont have an Account? Sign Up Now!"
            android:textAlignment="center"
            android:textColor="#BCBCBC"
            android:textSize="12sp" />

        <Button
            android:id="@+id/SignUpButton1"
            android:layout_width="251dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:backgroundTint="#2F2F2F"
            android:fontFamily="sans-serif-light"
            android:text="Sign Up"
            android:textColor="@color/white"
            android:textSize="15sp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>